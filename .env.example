# Polymarket wallet private key (Polygon network)
POLYMARKET_PRIVATE_KEY=

# Proxy wallet address (Polymarket UI → Profile → Settings에서 확인)
# Polymarket 웹에서 디파짓한 경우 반드시 설정 필요
POLYMARKET_FUNDER=
# Signature type: 0=EOA(MetaMask 직접), 1=POLY_PROXY(Polymarket 프록시), 2=GNOSIS_SAFE
POLYMARKET_SIGNATURE_TYPE=0

# Polygon chain ID (137 = mainnet)
CHAIN_ID=137

# Trading mode: true = paper trading (no real orders), false = live trading
PAPER_MODE=true

# Bankroll and risk management
INITIAL_BANKROLL=1000
MAX_POSITION_PCT=0.10
KELLY_MULTIPLIER=0.25
MIN_EV_THRESHOLD=0.03
MAX_DAILY_LOSS=100
MAX_OPEN_POSITIONS=5

# Market selection
MIN_LIQUIDITY=5000
MIN_VOLUME_24H=1000

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
